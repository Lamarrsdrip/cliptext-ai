# ClipText AI — Environment Variables
# Copy this file to .env and fill in the values you need.
# The app runs fully locally without any API keys.
# Transcription is the only feature that needs an external key.

# ── Transcription (optional but highly recommended) ───────────────────────────
# Add ONE of these to enable automatic transcription after recording/upload.
#
# Option A — Groq (preferred): fast Whisper, ~$0.04/hr, free tier available
#   Get your key at: https://console.groq.com/keys
# GROQ_API_KEY=
#
# Option B — OpenAI Whisper (fallback, slower but works fine)
#   Get your key at: https://platform.openai.com/api-keys
# OPENAI_API_KEY=

# ── Database (optional) ───────────────────────────────────────────────────────
# Leave blank for local SQLite (data/app.db) — perfect for personal use.
# Only set this if you want a persistent cloud DB.
# DATABASE_URL=postgresql://USER:PASSWORD@HOST/DB?sslmode=require
# DATABASE_AUTH_TOKEN=   # only needed for Turso/libSQL

# ── Internal ──────────────────────────────────────────────────────────────────
PING_MESSAGE=pong
